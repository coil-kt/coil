{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "automerge": false,
    "dependencyDashboard": false,
    "packageRules": [
        {
            "matchPackageNames": [
                "org.jetbrains.skiko:skiko",
            ],
            "enabled": false,
        },
    ],
}
